{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es6",
        "outDir": "lib",
        "lib": [
            "es6"
        ],
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "rootDir": "src",
        "strict": true,
        "noUnusedLocals": true,
        "isolatedDeclarations": true
    },
    "include": ["src"],
    "exclude": [
        "node_modules",
        "**/*.config.ts"
    ]
}