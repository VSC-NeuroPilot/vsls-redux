{
    "name": "@vsc-neuropilot/vsls-redux",
    "description": "A thin redux wrapper around the Live Share API to enable easily creating collaborative VS Code extensions",
    "type": "module",
    "version": "1.0.0",
    "author": {
        "name": "KTrain5369"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": "24.16.0"
        }
    },
    "packageManager": "pnpm@11.5.2",
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "fmt": "oxfmt",
        "lint": "oxlint --type-aware --type-check",
        "prepack": "pnpm build",
        "prepublishOnly": "pnpm run lint"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/VSC-NeuroPilot/vsls-redux"
    },
    "keywords": [
        "Live",
        "Share",
        "Redux"
    ],
    "bugs": {
        "url": "git+https://github.com/VSC-NeuroPilot/vsls-redux/issues"
    },
    "homepage": "https://github.com/VSC-NeuroPilot/vsls-redux",
    "dependencies": {
        "redux": "^5.0.1",
        "type-fest": "^5.7.0",
        "vsls": "^1.0.4753"
    },
    "devDependencies": {
        "@arethetypeswrong/core": "^0.18.3",
        "@changesets/cli": "^2.31.0",
        "@types/node": "^24.13.2",
        "oxfmt": "^0.54.0",
        "oxlint": "^1.69.0",
        "oxlint-tsgolint": "^0.23.0",
        "publint": "^0.3.21",
        "tsdown": "^0.22.2",
        "typescript": "^6.0.3"
    },
    "files": [
        "lib/**/*",
        "README.md",
        "CHANGELOG.md"
    ],
    "exports": {
        ".": "./lib/index.mjs",
        "./package.json": "./package.json"
    }
}
