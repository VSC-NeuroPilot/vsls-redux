{
	"name": "@vsc-neuropilot/vsls-redux",
	"version": "0.0.1",
	"description": "A thin redux wrapper around the Live Share API to enable easily creating collaborative VS Code extensions",
	"keywords": [
		"Live",
		"Redux",
		"Share"
	],
	"homepage": "https://github.com/VSC-NeuroPilot/vsls-redux",
	"bugs": {
		"url": "git+https://github.com/VSC-NeuroPilot/vsls-redux/issues"
	},
	"author": {
		"name": "KTrain5369"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/VSC-NeuroPilot/vsls-redux.git"
	},
	"files": [
		"lib/**/*",
		"README.md",
		"CHANGELOG.md"
	],
	"type": "module",
	"exports": {
		".": "./lib/index.mjs",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"fmt": "oxfmt",
		"lint": "oxlint --type-aware --type-check",
		"prepack": "pnpm run build",
		"prepublishOnly": "pnpm run lint"
	},
	"dependencies": {
		"vsls": "^1.0.4753"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.3",
		"@changesets/cli": "^2.31.0",
		"@reduxjs/toolkit": "^2.12.0",
		"@types/node": "^24.13.2",
		"oxfmt": "^0.56.0",
		"oxlint": "^1.69.0",
		"oxlint-tsgolint": "^0.23.0",
		"publint": "^0.3.21",
		"redux": "^5.0.1",
		"tsdown": "^0.22.2",
		"typescript": "^6.0.3"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.10.0",
			"onFail": "warn"
		},
		"runtime": {
			"name": "node",
			"version": "24.18.0",
			"onFail": "warn"
		}
	},
	"peerDependencies": {
		"@reduxjs/toolkit": "^2.12.0",
		"redux": "^5.0.1"
	}
}
