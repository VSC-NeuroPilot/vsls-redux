{
    "name": "vsls-redux",
    "displayName": "vsls-redux",
    "description": "A thin redux wrapper around the Live Share API to enable easily creating collaborative VS Code extensions",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "type": "module",
    "version": "1.0.0",
    "publisher": "daytonellwanger",
    "author": "daytonellwanger",
    "scripts": {
        "build": "tsc -p ./",
        "format": "prettier --write",
        "lint": "eslint -p tsconfig.json",
        "prepublishOnly": "npm run lint"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/vsls-contrib/vsls-redux"
    },
    "keywords": [
        "Live",
        "Share",
        "Redux"
    ],
    "bugs": {
        "url": "https://github.com/vsls-contrib/vsls-redux/issues"
    },
    "homepage": "https://github.com/vsls-contrib/vsls-redux",
    "dependencies": {
        "redux": "^5.0.1",
        "vsls": "^1.0.4753"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.3",
        "@typescript-eslint/eslint-plugin": "^8.61.0",
        "@typescript-eslint/parser": "^8.61.0",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.6.0",
        "prettier": "^3.8.4",
        "typescript": "^6.0.3"
    },
    "files": [
        "lib/**/*"
    ]
}
